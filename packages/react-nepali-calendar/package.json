{
  "name": "@sushilldhakal/react-nepali-calendar",
  "version": "1.0.0",
  "description": "Bikram Sambat calendar for React — dual BS/AD display on react-day-picker v9",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "nepali",
    "bikram-sambat",
    "calendar",
    "date-picker",
    "react-day-picker",
    "nepal"
  ],
  "homepage": "https://github.com/sushilldhakal/nepali-calendar#readme",
  "bugs": {
    "url": "https://github.com/sushilldhakal/nepali-calendar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushilldhakal/nepali-calendar.git",
    "directory": "packages/react-nepali-calendar"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-day-picker": "^9.0.0"
  },
  "dependencies": {
    "@sushilldhakal/bikram-sambat": "1.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
