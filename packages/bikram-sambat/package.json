{
  "name": "@sushill/bikram-sambat",
  "version": "1.0.0",
  "description": "Bikram Sambat (Nepali calendar) ↔ Gregorian conversion utilities",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nepali",
    "bikram-sambat",
    "bs",
    "calendar",
    "nepal",
    "date"
  ],
  "homepage": "https://github.com/sushilldhakal/nepali-calendar#readme",
  "bugs": {
    "url": "https://github.com/sushilldhakal/nepali-calendar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushilldhakal/nepali-calendar.git",
    "directory": "packages/bikram-sambat"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
